%option noyywrap
%{
    #include <stdio.h>
    #include <stdlib.h>
    #include "y.tab.h"
%}

%%
"Afficher" { return AFFICHER;}
"int"                { return INT; }
[0-9]+               { yylval.entier = atoi(yytext); return ENTIER; }
[A-Za-z][A-Za-z0-9]* { yylval.chaineCaracteres = strdup(yytext); return IDENT; }
"="                  { return EGALE; }
"+" {return PLUS;}
"-" {return MOINS;}
"*" {return FOIS;}
"/" {return DIVISER;}
"(" {return PAR_G;}
")"
";"                  { return PV; }
"\n"                 { return FIN; }

.                    {; }

%%